generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  searchHistory SearchHistory[]
  notes     Note[]
  diaries   DailyDiary[]
  bookmarks BookmarkedArticle[]
}

model DailyDiary {
  id        Int      @id @default(autoincrement())
  date      DateTime
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  @@unique([userId, date])
}

model BookmarkedArticle {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  outlet    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  @@unique([userId, url])
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  keyword   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
}

model Note {
  id        Int      @id @default(autoincrement())
  keyword   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  @@unique([userId, keyword])
}
